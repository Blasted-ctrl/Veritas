# ---------------------------------------------------------------------------
# Veritas environment configuration. Copy to `.env` and adjust.
# ---------------------------------------------------------------------------

# Reproducibility: every RNG (data splits, training) derives from this seed.
VERITAS_SEED=1337

# Root for datasets and model artifacts (mounted as a volume in compose).
VERITAS_DATA_ROOT=./data

# --- Inference API (Phase 4) ----------------------------------------------
VERITAS_API_HOST=0.0.0.0
VERITAS_API_PORT=8000
# Paths to exported ONNX models (produced by `veritas export`).
VERITAS_IMAGE_MODEL=./data/models/image/model.onnx
VERITAS_AUDIO_MODEL=./data/models/audio/model.onnx
# Max upload size in bytes (default 25 MB).
VERITAS_MAX_UPLOAD_BYTES=26214400

# --- Redis cache + Celery broker (Phase 4) --------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Frames sampled per second of video before fan-out aggregation.
VERITAS_VIDEO_FPS=1

# --- Frontend (Phase 5) ----------------------------------------------------
# Public base URL the Next.js app calls. In compose this is the api service.
NEXT_PUBLIC_API_URL=http://localhost:8000
